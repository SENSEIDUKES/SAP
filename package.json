{
  "name": "seihouse-audio-player",
  "version": "1.0.0",
  "description": "Portable, zero-dependency custom audio player (React + TypeScript)",
  "type": "module",
  "main": "./dist/index.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && npm run build:bundle && npm run build:types",
    "preview": "vite preview --outDir dist-demo --host 0.0.0.0",
    "preview:smoke": "node scripts/preview-smoke-test.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run build && npm run preview:smoke",
    "build:types": "tsc -p tsconfig.build.json",
    "build:bundle": "vite build && vite build --config vite.demo.config.ts"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^8.0.16"
  },
  "license": "UNLICENSED",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css"
  ]
}
