{
  "name": "seihouse-audio-player",
  "version": "1.0.0",
  "description": "Portable custom audio player (React + TypeScript) — zero-dependency core with optional lazy-loaded Automix Pro analysis and wavesurfer.js waveforms",
  "type": "module",
  "main": "src/audio-player/index.ts",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:smoke": "node scripts/preview-smoke-test.mjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test": "npm run typecheck && npm run test:unit && npm run build && npm run preview:smoke"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "essentia.js": "0.1.3",
    "wavesurfer.js": "^7.12.7"
  }
}
